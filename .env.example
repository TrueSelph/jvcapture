# LLM Provider Configuration
# Copy this file to .env and fill in your values.

# Default LLM provider: openai, anthropic, ollama, groq, openrouter
JVCAPTURE_LLM_PROVIDER=openai

# Default model for each provider (used when model is not specified in the request)
JVCAPTURE_LLM_MODEL=
JVCAPTURE_LLM_TEMPERATURE=0.7
JVCAPTURE_LLM_MAX_TOKENS=1000

# API keys — set the key for the provider(s) you use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Custom API endpoints (leave empty to use provider defaults)
JVCAPTURE_LLM_ENDPOINT=

# Ollama runs locally by default; no key needed
# JVCAPTURE_OLLAMA_ENDPOINT=http://localhost:11434